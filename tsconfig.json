{
  "compilerOptions": {
    // --- OpenTUI / React (TSX) ---
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/react",

    // --- Bun-recommended baseline ---
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // --- Strictness ---
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "types": ["bun"]
  },
  "include": ["src"]
}
